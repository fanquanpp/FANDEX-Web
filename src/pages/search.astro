---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
---

<Layout title="搜索">
  <SEO slot="head" title="搜索 - CODEX" description="全文搜索知识库" type="website" />
  <div class="search-page">
    <h1 class="search-title">搜索</h1>
    <div id="search" class="search-container"></div>
    <noscript>
      <p class="search-noscript">需要启用 JavaScript 才能使用搜索功能</p>
    </noscript>
  </div>
</Layout>

<style>
.search-page {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: var(--spacing-lg) var(--spacing-lg) var(--spacing-2xl);
}

.search-title {
  font-family: var(--font-display);
  font-size: 1.4em;
  margin-bottom: var(--spacing-lg);
}

.search-container {
  min-height: 400px;
}

.search-noscript {
  color: var(--color-text-tertiary);
  text-align: center;
  padding: var(--spacing-2xl);
}

:global(.pagefind-ui) {
  --pagefind-ui-scale: 1;
  --pagefind-ui-primary: var(--color-primary);
  --pagefind-ui-text: var(--color-text);
  --pagefind-ui-background: var(--color-bg);
  --pagefind-ui-border: var(--color-border);
  --pagefind-ui-tag: var(--color-bg-card);
  --pagefind-ui-border-width: 1px;
  --pagefind-ui-border-radius: 4px;
  --pagefind-ui-image-border-radius: 4px;
  --pagefind-ui-image-box-ratio: 3 / 2;
  --pagefind-ui-font: var(--font-display);
}
</style>

<script>
  async function initPagefind() {
    const base = import.meta.env.BASE_URL
    const searchEl = document.getElementById('search')
    if (!searchEl) return

    try {
      const pagefind = await import(/* @vite-ignore */ `${base}pagefind/pagefind.js`)
      await pagefind.init()

      const ui = new (pagefind as any).UI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      })

      const params = new URLSearchParams(window.location.search)
      const q = params.get('q')
      if (q) {
        ui.triggerSearch(q)
      }
    } catch (e) {
      searchEl.innerHTML = '<p style="color:var(--color-text-tertiary);text-align:center;padding:2em;">搜索索引尚未构建，请先运行 npm run build</p>'
    }
  }

  document.addEventListener('astro:page-load', initPagefind)
  initPagefind()
</script>
